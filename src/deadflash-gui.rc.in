#include <windows.h>
#include "resource.h"

IDI_DEADFLASH ICON "@DEADFLASH_GUI_ICON_RC@"
1 RT_MANIFEST "@DEADFLASH_GUI_MANIFEST_RC@"

1 VERSIONINFO
FILEVERSION 1,0,0,0
PRODUCTVERSION 1,0,0,0
FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
FILEFLAGS VS_FF_DEBUG
#else
FILEFLAGS 0x0L
#endif
FILEOS VOS_NT_WINDOWS32
FILETYPE VFT_APP
FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "DEADBYTE\0"
            VALUE "FileDescription", "DEADFLASH Image Writer & Verifier\0"
            VALUE "FileVersion", "1.0.0\0"
            VALUE "InternalName", "deadflash-gui\0"
            VALUE "LegalCopyright", "Copyright (c) DEADBYTE\0"
            VALUE "OriginalFilename", "deadflash-gui.exe\0"
            VALUE "ProductName", "DEADFLASH\0"
            VALUE "ProductVersion", "1.0.0\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
